@model ComparadorExcel.Models.ResultadoViewModel

@{
    ViewData["Title"] = "Resultado";
}

<div class="container mt-5">

    <h2 class="mb-4 text-primary">
        Resultado de la comparación
    </h2>

    <!-- RESUMEN -->
    <div class="row mb-4">

        <div class="col-md-3">
            <div class="card border-primary shadow">
                <div class="card-body text-center">
                    <h3>@Model.TotalArchivos</h3>
                    <small>Archivos analizados</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success shadow">
                <div class="card-body text-center">
                    <h3>@Model.TotalRegistros</h3>
                    <small>Registros leídos</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-warning shadow">
                <div class="card-body text-center">
                    <h3>@Model.TotalRepetidos</h3>
                    <small>Estudiantes repetidos</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-danger shadow">
                <div class="card-body text-center">
                    <h3>@Model.TotalSinDocumento</h3>
                    <small>Sin documento</small>
                </div>
            </div>
        </div>

    </div>


    <!-- ARCHIVOS CON ERROR -->
    @if (Model.Errores.Any())
    {
        <div class="card border-danger shadow mb-4">

            <div class="card-header bg-danger text-white">
                ⚠️ Archivos que no pudieron ser procesados
            </div>

            <div class="card-body">

                <p>
                    Los siguientes archivos presentaron errores y fueron omitidos
                    de la comparación:
                </p>

                <div class="table-responsive">

                    <table class="table table-bordered table-striped">

                        <thead class="table-danger">

                            <tr>

                                <th>
                                    Archivo
                                </th>

                                <th>
                                    Motivo
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var error in Model.Errores)
                            {
                                <tr>

                                    <td>
                                        @error.Archivo
                                    </td>

                                    <td>
                                        @error.Motivo
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>
    }


    <!-- TABLA DE RESULTADOS -->
    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            Estudiantes repetidos
        </div>

        <div class="card-body">

            @if (Model.Resultados.Any())
            {
                <div class="table-responsive">

                    <table class="table table-striped table-hover">

                        <thead class="table-dark">

                            <tr>

                                <th>
                                    Documento
                                </th>

                                <th>
                                    Nombre
                                </th>

                                <th>
                                    Veces
                                </th>

                                <th>
                                    Programas / Áreas
                                </th>

                                <th>
                                    Instituciones
                                </th>

                                <th>
                                    Archivos
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var estudiante in Model.Resultados)
                            {
                                <tr>

                                    <td>
                                        @estudiante.Documento
                                    </td>

                                    <td>
                                        @estudiante.Nombre
                                    </td>

                                    <td>
                                        @estudiante.Cantidad
                                    </td>

                                    <td>

                                        @foreach (var programa in estudiante.Programas)
                                        {
                                            <div>
                                                @programa
                                            </div>
                                        }

                                    </td>

                                    <td>

                                        @foreach (var institucion in estudiante.Instituciones)
                                        {
                                            <div>
                                                @institucion
                                            </div>
                                        }

                                    </td>

                                    <td>

                                        @foreach (var archivo in estudiante.Archivos)
                                        {
                                            <div>
                                                @archivo
                                            </div>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="alert alert-info">

                    No se encontraron estudiantes repetidos.

                </div>
            }

        </div>

    </div>


    <!-- BOTONES -->
    <div class="mt-4 d-flex gap-2">

        <!-- DESCARGAR EXCEL -->
        <a asp-controller="Estudiantes"
           asp-action="DescargarExcel"
           asp-route-id="@ViewBag.ReporteId"
           class="btn btn-success">

            📊 Descargar resultados en Excel

        </a>


        <!-- VOLVER -->
        <a asp-controller="Estudiantes"
           asp-action="Index"
           class="btn btn-secondary">

            Volver

        </a>

    </div>

</div>